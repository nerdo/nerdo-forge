{
  "name": "nerdo-forge",
  "version": "1.7.0",
  "description": "Custom statusline with jj/language detection and Disciplined Engineering output style",
  "author": {
    "name": "nerdo"
  },
  "license": "MIT",
  "keywords": [
    "statusline",
    "jujutsu",
    "output-style",
    "engineering"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pd-protocol-init.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pd-protocol-pre-compact.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pd-protocol-prompt.sh"
          }
        ]
      }
    ]
  }
}
