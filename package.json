{
  "name": "nerdo-forge-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["plugins/nerdo-essentials", "plugins/nerdo-mcp-bundle", "plugins/jj-snapshot"],
  "scripts": {
    "build": "bun run --cwd plugins/nerdo-essentials build",
    "typecheck": "bun run --cwd plugins/nerdo-essentials typecheck",
    "test": "bun run --cwd plugins/nerdo-essentials test",
    "version:sync": "bun run --cwd plugins/nerdo-essentials version:sync",
    "bump:patch": "bun run --cwd plugins/nerdo-essentials bump:patch",
    "bump:minor": "bun run --cwd plugins/nerdo-essentials bump:minor",
    "bump:major": "bun run --cwd plugins/nerdo-essentials bump:major"
  }
}
